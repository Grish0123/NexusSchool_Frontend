# Copy to .env for local dev if you want to point at a deployed backend
# instead of the local proxy. Leave EMPTY/unset to use the Vite dev proxy
# (vite.config.js) which forwards /api -> http://localhost:5176.
#
# In PRODUCTION (GitHub Actions build) this is set via the repo Variable
# VITE_API_BASE, e.g. https://api.nexus.edu.np
VITE_API_BASE=
